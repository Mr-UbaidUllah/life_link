<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- APNs environment for Firebase Cloud Messaging. Xcode/automatic signing
	     switches this to "production" for release/Ad Hoc/App Store builds.
	     This file is only active once it is referenced by the Runner target
	     (Signing & Capabilities → Push Notifications in Xcode). -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
