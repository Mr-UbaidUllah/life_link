<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Life Link</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>blood_donation</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Photo library access for the image picker (profile photos, organization
	     and ambulance images, chat attachments, etc.). Required or the app
	     crashes on first pick. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Life Link needs access to your photos so you can set a profile picture and attach images and videos to your messages and posts.</string>

	<!-- Camera + microphone access for capturing photos and recording videos to
	     send in chat. Required or the app crashes when the camera is opened. -->
	<key>NSCameraUsageDescription</key>
	<string>Life Link needs camera access so you can take photos and record videos to send in your messages.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Life Link needs microphone access so your recorded videos include sound.</string>

	<!-- Schemes the app probes with canLaunchUrl before opening the dialer or
	     email composer (url_launcher). Without these, canLaunchUrl returns false. -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>tel</string>
		<string>mailto</string>
	</array>

	<!-- Allow Firebase Cloud Messaging to deliver pushes while backgrounded. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!-- Location for proximity matching (geolocator): show distance to blood
	     requests and sort by nearest. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Life Link uses your location to show nearby blood requests and how far away each one is.</string>

	<!-- Export compliance: the app uses only standard HTTPS/TLS encryption, so
	     it is exempt. Setting this avoids the encryption question on every
	     TestFlight / App Store upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
