rules_version = '2';

// Life Link — Cloud Storage security rules
// Images are world-readable (they're shown via download URLs across the app),
// but only authenticated users can upload, and only reasonably-sized images.
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isImageUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024
             && request.resource.contentType.matches('image/.*');
    }

    match /profile_images/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImageUnder10MB();
    }
    match /organization_images/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImageUnder10MB();
    }
    match /ambulance_images/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImageUnder10MB();
    }
    match /volunteer_images/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImageUnder10MB();
    }

    // Everything else denied by default.
  }
}
