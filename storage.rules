rules_version = '2';

// Life Link — Cloud Storage security rules
//
// Reads require auth (the app fetches images via tokenized download URLs, which
// keep working regardless; this only stops anonymous bucket-path enumeration).
// Writes require auth + a sane image, and profile photos may only be written to
// the signed-in user's own `<uid>.jpg` path.
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isImageUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024
             && request.resource.contentType.matches('image/.*');
    }

    match /profile_images/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
                   && isImageUnder10MB()
                   && fileName == request.auth.uid + '.jpg';
    }
    match /organization_images/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder10MB();
    }
    match /ambulance_images/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder10MB();
    }
    match /volunteer_images/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUnder10MB();
    }

    // Everything else denied by default.
  }
}
