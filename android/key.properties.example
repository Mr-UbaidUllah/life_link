# Release signing config for the Play Store build.
#
# 1. Generate a keystore (keep the .jks file somewhere safe, OUTSIDE the repo):
#      keytool -genkey -v -keystore ~/lifelink-release.jks \
#        -keyalg RSA -keysize 2048 -validity 10000 -alias lifelink
#
# 2. Copy this file to `android/key.properties` and fill in the real values.
#    `android/key.properties` is gitignored — never commit it or the .jks.
#
# storeFile may be an absolute path or relative to the android/app directory.

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=lifelink
storeFile=/absolute/path/to/lifelink-release.jks
