rules_version = '2';

// Life Link — Firestore security rules
//
// Principles:
//  - only authenticated users get any access;
//  - users own their own profile;
//  - blood requests support the full donor workflow (accept / cancel / complete)
//    without letting third parties tamper with someone else's request;
//  - directory entries (ambulances/orgs/volunteers) are readable by all signed-in
//    users, created by members, but only editable/deletable by their creator or
//    an admin;
//  - role-based access via a `role` field on the user document ('user' | 'admin').
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && userRole() == 'admin';
    }

    // Keys changed between the existing doc and the incoming write.
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ---- Users & their subcollections ----
    match /users/{uid} {
      // Any signed-in user can read profiles (needed for chat, directories,
      // donor lookup). Only the owner can create/modify their own profile.
      allow read: if signedIn();
      // A new profile may only be self-created and must not grant itself admin.
      allow create: if signedIn() && request.auth.uid == uid
                    && (!('role' in request.resource.data)
                        || request.resource.data.role == 'user');
      // Owners cannot self-promote: an update must not change `role` unless an
      // admin makes it. (A normal owner write that leaves role untouched passes.)
      allow update: if signedIn() && request.auth.uid == uid
                    && (!('role' in changedKeys()) );
      allow update, delete: if isAdmin();

      // Notifications: the owner reads and manages their own; any signed-in
      // user may CREATE a notification addressed to this user (chat/donor
      // alerts), but the notification's receiverId must match the path owner.
      match /notifications/{notificationId} {
        allow read, update, delete: if signedIn() && request.auth.uid == uid;
        allow create: if signedIn()
                      && request.resource.data.receiverId == uid;
      }
    }

    // ---- Blood requests ----
    match /Blood_request/{requestId} {
      allow read: if signedIn();

      // Create: caller must own the request and provide a valid blood group and
      // a positive bag count.
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.bloodGroup is string
                    && request.resource.data.bloodGroup.size() > 0
                    && request.resource.data.bags is int
                    && request.resource.data.bags > 0;

      // Owner (or admin) can fully update / delete their request.
      allow update, delete: if signedIn()
                            && (resource.data.userId == request.auth.uid || isAdmin());

      // A donor ACCEPTS an open request: claims it, moving open -> in_progress,
      // touching ONLY status + acceptedByUserId.
      allow update: if signedIn()
                    && resource.data.status == 'open'
                    && request.resource.data.status == 'in_progress'
                    && request.resource.data.acceptedByUserId == request.auth.uid
                    && changedKeys().hasOnly(['status', 'acceptedByUserId']);

      // The accepting donor CANCELS their acceptance, reverting to open.
      allow update: if signedIn()
                    && resource.data.acceptedByUserId == request.auth.uid
                    && request.resource.data.status == 'open'
                    && changedKeys().hasOnly(['status', 'acceptedByUserId']);
    }

    // ---- Chats & messages ----
    match /chats/{chatRoomId} {
      // Gate on the `users` array (not the doc id) so the inbox list query
      // (where('users', arrayContains: uid)) can be evaluated by Firestore.
      allow read: if signedIn() && request.auth.uid in resource.data.users;
      allow create: if signedIn()
                    && request.auth.uid in request.resource.data.users;
      allow update, delete: if signedIn()
                            && request.auth.uid in resource.data.users;

      match /messages/{messageId} {
        allow read, write: if signedIn()
                           && request.auth.uid in
                              get(/databases/$(database)/documents/chats/$(chatRoomId)).data.users;
      }
    }

    // ---- Directory listings ----
    // Read by all signed-in users; created by members (must stamp themselves as
    // creator); edited/deleted only by the creator or an admin.
    function ownsDirectoryDoc() {
      return signedIn() && resource.data.createdBy == request.auth.uid;
    }
    function createsAsSelf() {
      return signedIn() && request.resource.data.createdBy == request.auth.uid;
    }

    match /Ambulance/{docId} {
      allow read: if signedIn();
      allow create: if createsAsSelf();
      allow update, delete: if ownsDirectoryDoc() || isAdmin();
    }
    match /organizations/{docId} {
      allow read: if signedIn();
      allow create: if createsAsSelf();
      allow update, delete: if ownsDirectoryDoc() || isAdmin();
    }
    match /Volunteer/{docId} {
      allow read: if signedIn();
      allow create: if createsAsSelf();
      allow update, delete: if ownsDirectoryDoc() || isAdmin();
    }

    // Everything else is denied by default.
  }
}
